# ─────────────────────────────────────────────────────────────────────────────
# RetailFlux — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

ENVIRONMENT=development   # development | production

# ─── App Security ─────────────────────────────────────────────────────────
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Database — Local: docker-compose; Prod: Neon (neon.tech, free 0.5 GB) ─
DATABASE_URL=postgresql+asyncpg://retailflux:retailflux_dev@localhost:5432/retailflux
# Prod example:
# DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# ─── Redis — Local: docker; Prod: Upstash (upstash.com, free 10K cmd/day) ──
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
# Prod (Upstash — use rediss:// for TLS):
# REDIS_URL=rediss://default:token@xxx.upstash.io:6379

# ─── MongoDB — Local: docker; Prod: MongoDB Atlas M0 (512 MB free) ─────────
MONGODB_URL=mongodb://retailflux:retailflux_dev@localhost:27017/retailflux?authSource=admin
MONGODB_DATABASE=retailflux
# Prod example:
# MONGODB_URL=mongodb+srv://user:pass@cluster0.xxx.mongodb.net/retailflux

# ─── Object Storage — Local: MinIO; Prod: Cloudflare R2 (10 GB/mo free) ───
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=retailflux
MINIO_SECRET_KEY=retailflux_dev
MINIO_USE_SSL=false
MINIO_BUCKET_UPLOADS=retailflux-uploads
# Prod (Cloudflare R2 — S3-compatible):
# MINIO_ENDPOINT=<account_id>.r2.cloudflarestorage.com
# MINIO_ACCESS_KEY=<r2_access_key>
# MINIO_SECRET_KEY=<r2_secret_key>
# MINIO_USE_SSL=true

# ─── LLM — Primary: Google Gemini Flash (free 1500 req/day) ────────────────
GEMINI_API_KEY=your-google-ai-studio-api-key
GEMINI_MODEL=gemini-2.5-flash-lite

# ─── LLM — Fallback: Groq (free 30 RPM, Llama-3.1-70B) ────────────────────
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-70b-versatile

# ─── Email — Resend (free 100 emails/day, 3K/mo) ──────────────────────────
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=noreply@yourdomain.com

# ─── Monitoring — Sentry (free 5K events/mo) ──────────────────────────────
SENTRY_DSN=
# Prod: paste your Sentry DSN here

# ─── Backend CORS (set to your Vercel URL in prod) ────────────────────────
FRONTEND_URL=http://localhost:3000
# Prod example: FRONTEND_URL=https://retailflux.vercel.app

# ─── Frontend (read by Vite — must be prefixed VITE_) ─────────────────────
VITE_API_URL=http://localhost:8000
# Prod: VITE_API_URL=https://retailflux-api.onrender.com
# WebSocket URL is derived automatically (http→ws, https→wss)
VITE_APP_NAME=RetailFlux
VITE_SENTRY_DSN=

# ─── Deployment secrets (GitHub Actions — DO NOT put real values here) ────────
# These are read by .github/workflows/deploy.yml and must be added as
# GitHub repository secrets (Settings → Secrets and variables → Actions).
#
# VERCEL_TOKEN       — Vercel dashboard → Settings → Tokens → create
# VERCEL_ORG_ID      — run `vercel link` in apps/web/, then read .vercel/project.json
# VERCEL_PROJECT_ID  — same file as above
# RENDER_DEPLOY_HOOK_URL — Render API service → Settings → Deploy Hook → copy URL
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
RENDER_DEPLOY_HOOK_URL=
